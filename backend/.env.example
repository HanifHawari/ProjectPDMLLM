# ==============================================================
# FitMind AI - Environment Variables
# ==============================================================
# SALIN file ini menjadi .env dan isi nilai yang benar

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- App Config ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Dataset Paths (relatif dari root WebsiteLLM/) ---
DATASET_BASE_PATH=../dataset

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
